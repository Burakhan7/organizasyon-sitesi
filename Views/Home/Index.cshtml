@model OrganizasyonSitesi.Models.ViewModels.AnasayfaViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="hero">
    <h1>Hayalinizdeki Etkinlik, Bizim İşimiz</h1>
    <p>Kurumsal lansmanlardan düğünlere, festivallerden açılışlara — planlamayı bize bırakın, siz anın tadını çıkarın.</p>
    <a class="btn btn-altin" asp-controller="Iletisim" asp-action="Index">Teklif Alın</a>
</section>

<section class="bolum">
    <div class="container">
        <h2 class="belir">Hizmetlerimiz</h2>
<p class="bolum-alt belir gecikme-1">Her ölçekte organizasyon için uçtan uca çözüm</p>
        <div class="row g-4">
            @foreach (var (hizmet, i) in Model.Hizmetler.Select((h, i) => (h, i)))
            {
                 <div class="col-md-6 col-lg-3 belir gecikme-@(Math.Min(i, 3))">
                    @{ var kartFoto = hizmet.Fotograflar.FirstOrDefault(); }
@if (!string.IsNullOrEmpty(hizmet.Slug))
{
    <a asp-controller="Hizmet" asp-action="Detay" asp-route-slug="@hizmet.Slug" class="hizmet-kart hizmet-kart-link">
        @if (kartFoto != null)
        {
            <div class="hizmet-gorsel">
                <img src="@kartFoto.DosyaYolu" alt="@hizmet.Baslik" loading="lazy" />
            </div>
        }
        <div class="hizmet-govde">
            <h5>@hizmet.Baslik</h5>
            <p>@hizmet.Aciklama</p>
            <span class="kart-ok">Detayları Gör →</span>
        </div>
    </a>
}
else
{
    <div class="hizmet-kart">
        @if (kartFoto != null)
        {
            <div class="hizmet-gorsel">
                <img src="@kartFoto.DosyaYolu" alt="@hizmet.Baslik" loading="lazy" />
            </div>
        }
        <div class="hizmet-govde">
            <h5>@hizmet.Baslik</h5>
            <p>@hizmet.Aciklama</p>
        </div>
    </div>
}
                </div>
            }
        </div>
    </div>
</section>

<section class="bolum referans-bolumu">
    <div class="container">
        <h2>Müşterilerimiz Ne Diyor?</h2>
        <p class="bolum-alt">Bizi en iyi onlar anlatır</p>
        <div class="row g-4">
            @foreach (var (referans, i) in Model.Referanslar.Select((r, i) => (r, i)))
            {
                <div class="col-md-4 belir gecikme-@(Math.Min(i, 3))">
                    <div class="referans-kart">
                        <p>"@referans.Yorum"</p>
                        <footer>— @referans.MusteriAdi</footer>
                    </div>
                </div>
            }
        </div>
    </div>
</section>