@model OrganizasyonSitesi.Models.ViewModels.IletisimFormViewModel

@{
    ViewData["Title"] = "Ýletiţim";
}

<h1 class="mb-4">Bize Ulaţýn</h1>

@if (TempData["Basarili"] != null)
{
    <div class="alert alert-success">@TempData["Basarili"]</div>
}

<form asp-action="Index" method="post" class="col-md-8">
    <div class="mb-3">
        <label asp-for="AdSoyad" class="form-label"></label>
        <input asp-for="AdSoyad" class="form-control" />
        <span asp-validation-for="AdSoyad" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefon" class="form-label"></label>
        <input asp-for="Telefon" class="form-control" />
        <span asp-validation-for="Telefon" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EtkinlikTuru" class="form-label"></label>
        <select asp-for="EtkinlikTuru" class="form-select">
            <option value="">Seçiniz...</option>
            <option>Kurumsal Etkinlik</option>
            <option>Düđün</option>
            <option>Festival / Konser</option>
            <option>Açýlýţ / Lansman</option>
            <option>Diđer</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Mesaj" class="form-label"></label>
        <textarea asp-for="Mesaj" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Mesaj" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Gönder</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}