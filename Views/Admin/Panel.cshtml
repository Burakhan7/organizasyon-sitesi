@{
    ViewData["Title"] = "Yönetim Paneli";
}

<section class="sayfa-baslik">
    <h1>Yönetim Paneli</h1>
    <p>Hoş geldin, @User.Identity?.Name</p>
</section>

<section class="bolum">
    <div class="container text-center">
        <p>Panel içeriği yakında burada olacak.</p>
        <form asp-action="Cikis" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Çıkış Yap</button>
        </form>
    </div>
</section>