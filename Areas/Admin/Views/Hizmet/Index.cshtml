@model List<OrganizasyonSitesi.Models.Entities.Hizmet>

    @{
    ViewData["Title"] = "Hizmetler";
    }

    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Hizmetler</h1>
            <a asp-action="Ekle" class="btn btn-primary">+ Yeni Hizmet</a>
        </div>

        @if (TempData["Basarili"] != null)
    {
        <div class="alert alert-success">@TempData["Basarili"]</div>
    }
        @if (TempData["Hatalar"] != null)
    {
        <div class="alert alert-warning">@TempData["Hatalar"]</div>
    }

        <div class="table-responsive">
            <table class="table admin-tablo align-middle">
                <thead>
                    <tr>
                        <th>Başlık</th>
                        <th>Sıra</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model)
                {
                    <tr>
                        <td>
                            <strong>@h.Baslik</strong>
                            @if (!string.IsNullOrEmpty(h.Slug))
                            {
                            <div class="mesaj-meta">/@h.Slug</div>
                            }
                        </td>
                        <td>@h.SiraNo</td>
                        <td>
                            @if (h.AktifMi)
                            {
                            <span class="rozet rozet-yayin">Aktif</span>
                            }
                            else
                            {
                            <span class="rozet rozet-taslak">Pasif</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Duzenle" asp-route-id="@h.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            <form asp-action="Sil" asp-route-id="@h.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu hizmeti silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
