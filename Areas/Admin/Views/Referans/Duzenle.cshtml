@model ReferansFormViewModel

@{
    ViewData["Title"] = "Referans Duzenle";
}

<div class="container-fluid px-4 py-4">
    <h1 class="mb-4">Yeni Referans</h1>
    <div class="col-lg-6">
        <form asp-action="Duzenle" method="post" class="iletisim-form">
            <partial name="_ReferansForm" model="Model" />
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}