@model List<OrganizasyonSitesi.Models.Entities.Referans>

    @{
    ViewData["Title"] = "Referanslar";
    }

    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Referanslar</h1>
            <a asp-action="Ekle" class="btn btn-primary">+ Yeni Referans</a>
        </div>

        @if (TempData["Basarili"] != null)
    {
        <div class="alert alert-success">@TempData["Basarili"]</div>
    }

        @if (!Model.Any())
    {
        <p class="text-muted">Henüz referans yok.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table admin-tablo align-middle">
                <thead>
                    <tr>
                        <th>Müşteri</th>
                        <th>Yorum</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                    <tr>
                        <td><strong>@r.MusteriAdi</strong></td>
                        <td class="mesaj-meta">@r.Yorum</td>
                        <td>
                            @if (r.AktifMi)
                                {
                            <span class="rozet rozet-yayin">Aktif</span>
                                }
                                else
                                {
                            <span class="rozet rozet-taslak">Pasif</span>
                                }
                        </td>
                        <td class="text-end">
                            <a asp-action="Duzenle" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            <form asp-action="Sil" asp-route-id="@r.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu referans silinecek. Emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    </div>
